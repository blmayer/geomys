#!/bin/sh

version="0.2.0"

usage() {
	echo "geomys v$version: Browse the gopher web on the terminal."
	echo ""
	echo "Usage: geomys [URL]|[OPTION]"
	echo ""
	echo "Options:"
	echo "  -h, --help		show this help"
	echo "  -v, --version		show version info"
	echo ""
	echo "Configuration:"
	echo "You can setup a config file at ~/.config/geomys/geomys.conf to configure *geomys* the way you like."
	echo ""
	echo "Commands:"
	echo "These are the default keybindings to use while running geomys:"
	echo ""
	echo "  q	quit"
	echo "  up/down	select previous/next link (scroll on text pages)"
	echo "  left/right	go back/forward in history"
	echo "  enter	follow the selected link"
	echo "  r	reload current page"
	echo "  b	go back one page"
	echo "  u	jump one path segment up"
	echo "  o	open an address"
	echo "  s	save current page"
	echo "  H	go to homepage"
	echo "  m	add bookmark"
	echo "  M	go to a bookmark"
	echo "  K	remove bookmark for current url"
	echo "  pgup/pgdn	scroll the page"
	echo ""
	echo "Examples:"
	echo "  geomys		Start browsing the default webpage"
	echo "  geomys url	Start browsing url"
	echo "  geomys --help	Show help"
	echo ""
	echo "Report bugs to: bleemayer@gmail.com"
	echo "Home page: <https://www.github.com/blmayer/geomys/>"
}

version() {
	echo "geomys $version"
	echo ""
	echo "Copyright (C) 2026 Brian Mayer."
	echo "License MIT: MIT License <https://opensource.org/licenses/MIT>"
	echo "THE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND,"
	echo "EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF"
	echo "MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT."
	echo ""
	echo "Written by Brian Lee Mayer."
}

debug() {
	[ "$debug" ] && echo "DEBUG: $*" >&2 && sleep "$debug"
}

# Parse arguments
debug "parsing args"
while [ "$1" ]
do
	case $1 in
		"-v")
			debug=1
			;;
		"-h" | "--help")
			usage
			exit 0
			;;
		"--version")
			version
			exit 0
			;;
		"-f"|"--file")
			shift
			file="$1"
			;;
		"")
			break
			;;
		*)
			url="$1"
			;;
	esac
	shift
done

# Save terminal
tput smcup

# Configuration
confighome=${XDG_CONFIG_HOME:-$HOME/.config}
mkdir -p "$confighome/geomys"
configfile="$confighome/geomys/geomys.conf"
bookmarkfile="$confighome/geomys/bookmarks"

cachedir="${XDG_CACHE_HOME:-$HOME/.cache}/geomys"

# Default values

# user config
margin=8
homepage="gopher.floodgap.com/1/"

# keybindings
openkey='o'
openlocalkey='O'
refreshkey='r'
backkey='b'
quitkey='q'
markkey='m'
gomarkkey='M'
delmarkkey='K'
goupkey='u'
homekey='H'
savekey='s'

# styles
sty_info='\033[2m'
sty_error='\033[31;1m'
sty_selected='\033[7m'
sty_search='\033[33;1m'
sty_dir='\033[34;1m'
sty_text='\033[39m'
sty_bin='\033[31m'
sty_html='\033[32m'
sty_image='\033[33m'

if [ ! -s "$configfile" ]
then
	# Default values
	cat <<- EOF > "$configfile"
	# where to store temp files
	cachedir="$cachedir"

	# user config
	margin=8
	homepage="gopher.floodgap.com/1/"

	# keybindings
	openkey='o'
	openlocalkey='O'
	refreshkey='r'
	backkey='b'
	quitkey='q'
	markkey='m'
	gomarkkey='M'
	delmarkkey='K'
	goupkey='u'
	homekey='H'
	savekey='s'

	# styles
	sty_info='\033[2m'
	sty_error='\033[31;1m'
	sty_selected='\033[7m'
	sty_search='\033[33;1m'
	sty_dir='\033[34;1m'
	sty_text='\033[39m'
	sty_bin='\033[31m'
	sty_html='\033[32m'
	sty_image='\033[33m'
	EOF
fi

# shellcheck source=/dev/null
. "$configfile"

# Defaults for options added after older config files were written
[ -n "$sty_selected" ] || sty_selected='\033[7m'

mkdir -p "$cachedir"
pagefile="$(mktemp -p "$cachedir" -t curpage.XXXXXX)"
rawfile="$(mktemp -p "$cachedir" -t rawpage.XXXXXX)"
histfile="$(mktemp -p "$cachedir" -t history.XXXXXX)"
linksfile="$(mktemp -p "$cachedir" -t links.XXXXXX)"
linkmapfile="$(mktemp -p "$cachedir" -t linkmap.XXXXXX)"
stylefile="$(mktemp -p "$cachedir" -t styles.XXXXXX)"
tracefile="$(mktemp -p "$cachedir" -t trace.XXXXXX)"
debug "read configs"

# Restore terminal
thetrap() {
	rm -f "$histfile" "$linksfile" "$linkmapfile" "$stylefile" "$pagefile" "$rawfile" "$tracefile" > /dev/null 2>&1
	tput rmcup
	printf "\033[?25h"
	stty echo
	exit
}

trap thetrap EXIT INT HUP

# Drop last line of a file (portable; BSD sed -i needs '', GNU does not)
histpos=0
histskip=""

hist_count() {
	if [ -f "$histfile" ]
	then
		wc -l < "$histfile" | tr -d ' '
	else
		echo 0
	fi
}

# Record a successful visit; drops any forward entries beyond histpos
hist_push() {
	if [ "$histpos" -gt 0 ] && [ -f "$histfile" ]
	then
		head -n "$histpos" "$histfile" > "$histfile.tmp" && mv "$histfile.tmp" "$histfile"
	else
		: > "$histfile"
	fi
	echo "$1 $2 $3 $4 $5" >> "$histfile"
	histpos="$(hist_count)"
}

# Build url from a history line (proto host port itype selector)
hist_entry_to_url() {
	read -r _hp _hh _hpo _hi _hs <<- EOF
	$1
	EOF
	_hdisp=""
	[ "$_hpo" != "70" ] && _hdisp=":$_hpo"
	echo "$_hp://$_hh$_hdisp/$_hi$_hs"
}

# Move history cursor by $1 (-1 back, +1 forward); sets url and histskip
hist_navigate() {
	_dir="$1"
	_cnt="$(hist_count)"
	[ "$_cnt" -lt 1 ] && return 1
	_new=$((histpos + _dir))
	[ "$_new" -lt 1 ] && return 1
	[ "$_new" -gt "$_cnt" ] && return 1
	histpos="$_new"
	_entry="$(sed "${histpos}q;d" "$histfile")"
	[ -z "$_entry" ] && return 1
	url="$(hist_entry_to_url "$_entry")"
	gophersearch=""
	histskip=1
	return 0
}

# Reload url from the current history position (e.g. after a failed fetch)
hist_restore_current() {
	if [ "$histpos" -ge 1 ]
	then
		_entry="$(sed "${histpos}q;d" "$histfile")"
		if [ -n "$_entry" ]
		then
			url="$(hist_entry_to_url "$_entry")"
			gophersearch=""
			histskip=1
			return 0
		fi
	fi
	url="$homepage"
	gophersearch=""
	histskip=""
	return 1
}

# Returns the complete url scheme with gopher defaults
# Parameters: url
# Gopher URL format: gopher://host[:port]/type][/selector]
# See RFC 4266
parseurl() {
	debug "parsing: $url oldhost: $oldhost oldselector: $oldselector"
	proto="$(echo "$url" | grep :// | sed -e 's,^\(.*://\).*,\1,g')"
	if [ "$proto" ]
	then
		url="$(echo "$url" | sed -e "s@$proto@@g")"
	else
		if [ "$oldhost" ]
		then
			case "$url" in
				"/"*) url="$oldhost$url" ;;
				*)
					# relative selector under current host
					url="$oldhost${oldselector%/*}/$url"
					;;
			esac
		fi
	fi
	debug "url: $url"

	proto="$(echo "$proto" | sed -e 's,://,,g')"
	hostport="$(echo "$url" | cut -d/ -f1)"
	host="$(echo "$hostport" | sed -e 's,:.*,,g')"
	port="$(echo "$hostport" | sed -e 's,^.*:,:,g' -e 's,.*:\([0-9]*\).*,\1,g' -e 's,[^0-9],,g')"
	rest="$(echo "$url" | sed "s@^$hostport@@")"

	# First character after host is item type, rest is selector
	# e.g. /1/foo/bar -> type=1, selector=/foo/bar
	# e.g. /0/readme  -> type=0, selector=/readme
	# e.g. /          -> type=1, selector=
	# e.g. (empty)    -> type=1, selector=
	if [ -z "$rest" ] || [ "$rest" = "/" ]
	then
		itype="1"
		selector=""
	else
		# strip leading /
		rest="${rest#/}"
		itype="$(printf '%s' "$rest" | cut -c1)"
		selector="$(printf '%s' "$rest" | cut -c2-)"
	fi

	# Validate item type is a single known character; if not treat whole as selector
	case "$itype" in
		[0-9a-zA-Z+]) ;;
		*)
			itype="1"
			selector="/$rest"
			;;
	esac

	debug "parsed: proto: ${proto:-gopher} host: $host port: ${port:-70} type: $itype selector: $selector"
	echo "${proto:-gopher}" "$host" "${port:-70}" "$itype" "$selector"
}

# Print margin-indented, folded plain text. Styles are applied at draw time
# from stylefile so selection reverse video is not overridden by resets.
# If pending_link is set, records the link and its inclusive line range.
emit_text() {
	_sty="$1"
	_text="$2"
	_start=$((pageline + 1))
	printf -- "%s\n" "$_text" | fold -w "$width" -s | while IFS='' read -r txt
	do
		printf "%s\n" "$txt"
	done
	_nfolded="$(printf -- "%s\n" "$_text" | fold -w "$width" -s | wc -l | tr -d ' ')"
	[ -z "$_text" ] && _nfolded=1
	_j=0
	while [ "$_j" -lt "$_nfolded" ]
	do
		printf '%s\n' "$_sty" >> "$stylefile"
		_j=$((_j + 1))
	done
	pageline=$((pageline + _nfolded))
	if [ -n "$pending_link" ]
	then
		echo "$pending_link" >> "$linksfile"
		echo "$_start $pageline" >> "$linkmapfile"
		pending_link=""
	fi
}

# Queue a selectable link; finalized by the next emit_text call
record_link() {
	pending_link="$1"
}

typesetgopher() {
	: > "$linksfile"
	: > "$linkmapfile"
	: > "$stylefile"
	cols=$(tput cols)
	pageline=0
	pending_link=""

	# shellcheck disable=SC2154
	width=$((cols - (2*margin)))
	debug "text width: $width"

	while IFS='' read -r line || [ -n "$line" ];
	do
		line="$(printf "%s" "$line" | tr -d '\r')"

		# End of menu marker
		[ "$line" = "." ] && continue
		[ -z "$line" ] && continue

		# Gopher menu line: type + display + TAB + selector + TAB + host + TAB + port
		itype="$(printf '%s' "$line" | cut -c1)"
		rest="$(printf '%s' "$line" | cut -c2-)"

		display="$(printf '%s' "$rest" | cut -f1)"
		selector="$(printf '%s' "$rest" | cut -f2)"
		lhost="$(printf '%s' "$rest" | cut -f3)"
		lport="$(printf '%s' "$rest" | cut -f4)"

		case "$itype" in
			i)
				pending_link=""
				emit_text "$sty_info" "$display"
				continue
				;;
			3)
				pending_link=""
				emit_text "$sty_error" "$display"
				continue
				;;
			h)
				case "$selector" in
					"URL:"*) linkurl="${selector#URL:}" ;;
					*) linkurl="gopher://$lhost:${lport:-70}/h$selector" ;;
				esac
				record_link "$linkurl"
				emit_text "$sty_html" "$display"
				;;
			7)
				record_link "SEARCH gopher://$lhost:${lport:-70}/7$selector"
				emit_text "$sty_search" "$display"
				;;
			1)
				record_link "gopher://$lhost:${lport:-70}/1$selector"
				case "$display" in
					*/) emit_text "$sty_dir" "$display" ;;
					*) emit_text "$sty_dir" "${display}/" ;;
				esac
				;;
			0)
				record_link "gopher://$lhost:${lport:-70}/0$selector"
				emit_text "$sty_text" "$display"
				;;
			9|4|5|6|g|I|s)
				record_link "gopher://$lhost:${lport:-70}/$itype$selector"
				case "$itype" in
					g|I) emit_text "$sty_image" "$display" ;;
					*) emit_text "$sty_bin" "$display" ;;
				esac
				;;
			8|T)
				record_link "telnet://$lhost:${lport:-23}/"
				emit_text "$sty_bin" "$display"
				;;
			*)
				record_link "gopher://$lhost:${lport:-70}/$itype$selector"
				emit_text "$sty_text" "$display"
				;;
		esac
	done
}

typesettext() {
	: > "$linksfile"
	: > "$linkmapfile"
	: > "$stylefile"
	cols=$(tput cols)
	# shellcheck disable=SC2154
	width=$((cols - (2*margin)))

	while IFS='' read -r line || [ -n "$line" ];
	do
		line="$(printf "%s" "$line" | tr -d '\r')"
		# Text files may end with lone period
		[ "$line" = "." ] && continue

		printf -- "%s\n" "$line" | fold -w "$width" -s | while IFS='' read -r txt
		do
			printf "%s\n" "$txt"
		done
		_nfolded="$(printf -- "%s\n" "$line" | fold -w "$width" -s | wc -l | tr -d ' ')"
		[ -z "$line" ] && _nfolded=1
		_j=0
		while [ "$_j" -lt "$_nfolded" ]
		do
			printf '\n' >> "$stylefile"
			_j=$((_j + 1))
		done
	done
}

# Follow link index $1 from linksfile; sets url/gophersearch and returns 0 to leave pager
follow_link() {
	_idx="$1"
	[ -z "$_idx" ] || [ "$_idx" -lt 1 ] && return 1
	linkentry="$(sed "${_idx}q;d" "$linksfile")"
	[ -z "$linkentry" ] && return 1
	debug "following $linkentry"
	case "$linkentry" in
		"SEARCH "*)
			searchurl="${linkentry#SEARCH }"
			printf '\033[%sH\033[?25h\033[2KSearch query: ' "$lines"
			stty echo icanon
			read -r query
			url="$searchurl"
			gophersearch="$query"
			;;
		"telnet://"*)
			printf '\033[%sH\033[?25h\033[2KTelnet links not supported in-browser: %s\nPress enter.' "$lines" "$linkentry"
			stty echo icanon
			read -r _
			stty -echo -icanon min 1 time 0
			printf '\033[?25l'
			return 1
			;;
		"http://"*|"https://"*)
			printf '\033[%sH\033[?25h\033[2KHTTP links not supported in-browser: %s\nPress enter.' "$lines" "$linkentry"
			stty echo icanon
			read -r _
			stty -echo -icanon min 1 time 0
			printf '\033[?25l'
			return 1
			;;
		*)
			url="$linkentry"
			gophersearch=""
			;;
	esac
	return 0
}

# Load selstart/selend for the current selected link index
load_selection_range() {
	selstart=0
	selend=0
	[ "$selected" -lt 1 ] && return
	_range="$(sed "${selected}q;d" "$linkmapfile")"
	[ -z "$_range" ] && return
	selstart="$(echo "$_range" | cut -d' ' -f1)"
	selend="$(echo "$_range" | cut -d' ' -f2)"
	[ -z "$selend" ] && selend="$selstart"
}

pager_sync_viewend() {
	contentrows=$((lines - 1))
	[ "$contentrows" -lt 1 ] && contentrows=1
	viewend=$((viewstart + contentrows - 1))
	[ "$viewend" -gt "$l" ] && viewend="$l"
	[ "$viewend" -lt 1 ] && viewend=0
}

# Compute viewstart needed to keep the selection visible (no side effects)
pager_needed_viewstart() {
	contentrows=$((lines - 1))
	[ "$contentrows" -lt 1 ] && contentrows=1
	_vs="$viewstart"
	if [ "$selstart" -gt 0 ]
	then
		if [ "$selstart" -lt "$_vs" ]
		then
			_vs="$selstart"
		elif [ "$selend" -gt $((_vs + contentrows - 1)) ]
		then
			_vs=$((selend - contentrows + 1))
		fi
	fi
	[ "$_vs" -lt 1 ] && _vs=1
	if [ "$l" -gt "$contentrows" ]
	then
		_maxstart=$((l - contentrows + 1))
		[ "$_vs" -gt "$_maxstart" ] && _vs="$_maxstart"
	else
		_vs=1
	fi
	echo "$_vs"
}

pager_clear_status() {
	printf '\033[%s;1H\033[2K' "$lines"
}

# Build a reverse-video variant of an SGR style, keeping its colors.
# Styles are stored as printf escapes (e.g. \033[34;1m); invert merges ;7
# into the SGR so a blue link becomes \033[34;1;7m (blue reversed), not plain B/W.
style_invert() {
	_base="$1"
	# Drop reset-only SGR (literal \033 or real ESC) — nothing to invert
	_base="$(printf '%s' "$_base" | sed -e 's/\\033\[0*m//g' -e "$(printf 's/\033\\[0*m//g')")"
	if [ -z "$_base" ]
	then
		printf '%s' "$sty_selected"
		return
	fi
	printf '%s' "$_base" | sed 's/m$/;7m/'
}

# Paint one page line at its current screen row.
# Leading margin is never reversed — only the link text is.
# Selection inverts the link's own colors instead of plain black/white reverse.
paint_line() {
	_lineno="$1"
	[ "$_lineno" -lt 1 ] && return
	_row=$((_lineno - viewstart + 1))
	[ "$_row" -lt 1 ] || [ "$_row" -gt "$contentrows" ] && return

	_line="$(sed "${_lineno}q;d" "$pagerfile")"
	_sty="$(sed "${_lineno}q;d" "$stylefile" 2>/dev/null)"
	printf '\033[%s;1H\033[2K' "$_row"
	printf "%*s" "$margin" ""
	if [ "$nlinks" -gt 0 ] && [ "$selstart" -gt 0 ] \
		&& [ "$_lineno" -ge "$selstart" ] && [ "$_lineno" -le "$selend" ]
	then
		_selsty="$(style_invert "$_sty")"
		# shellcheck disable=SC2059
		printf -- "$_selsty%s\033[m" "$_line"
	elif [ -n "$_sty" ]
	then
		# shellcheck disable=SC2059
		printf -- "$_sty%s\033[m" "$_line"
	else
		printf '%s' "$_line"
	fi
}

paint_range() {
	_rfrom="$1"
	_rto="$2"
	[ "$_rfrom" -lt 1 ] && return
	[ "$_rto" -lt "$_rfrom" ] && return
	_ri="$_rfrom"
	while [ "$_ri" -le "$_rto" ]
	do
		paint_line "$_ri"
		_ri=$((_ri + 1))
	done
}

# Full redraw — only for initial display or after overwriting the screen
pager_draw() {
	clear
	printf '\033[?25l'
	lines="$(tput lines)"
	contentrows=$((lines - 1))
	[ "$contentrows" -lt 1 ] && contentrows=1
	load_selection_range
	viewstart="$(pager_needed_viewstart)"
	pager_sync_viewend

	_i="$viewstart"
	while [ "$_i" -le "$viewend" ]
	do
		paint_line "$_i"
		_i=$((_i + 1))
	done
	pager_clear_status
}

# Scroll the viewport by inserting/deleting lines; paints only entering lines
pager_scroll_by() {
	_delta="$1"
	[ "$_delta" -eq 0 ] && return 0
	contentrows=$((lines - 1))
	[ "$contentrows" -lt 1 ] && contentrows=1
	if [ "$l" -le "$contentrows" ]
	then
		[ "$viewstart" -eq 1 ] && return 1
		viewstart=1
		pager_sync_viewend
		return 0
	fi
	_maxstart=$((l - contentrows + 1))
	_target=$((viewstart + _delta))
	[ "$_target" -lt 1 ] && _target=1
	[ "$_target" -gt "$_maxstart" ] && _target="$_maxstart"
	[ "$_target" -eq "$viewstart" ] && return 1

	if [ "$_target" -gt "$viewstart" ]
	then
		_steps=$((_target - viewstart))
		_s=0
		while [ "$_s" -lt "$_steps" ]
		do
			printf '\033[1;1H\033[M'
			viewstart=$((viewstart + 1))
			pager_sync_viewend
			paint_line "$viewend"
			pager_clear_status
			_s=$((_s + 1))
		done
	else
		_steps=$((viewstart - _target))
		_s=0
		while [ "$_s" -lt "$_steps" ]
		do
			printf '\033[1;1H\033[L'
			viewstart=$((viewstart - 1))
			pager_sync_viewend
			paint_line "$viewstart"
			pager_clear_status
			_s=$((_s + 1))
		done
	fi
	return 0
}

# Move selection onto a link visible in the current viewport
pager_select_visible() {
	[ "$nlinks" -lt 1 ] && return
	pager_sync_viewend
	load_selection_range
	if [ "$selstart" -ge "$viewstart" ] && [ "$selend" -le "$viewend" ]
	then
		return
	fi
	_old_s="$selstart"
	_old_e="$selend"
	_j=1
	while [ "$_j" -le "$nlinks" ]
	do
		_range="$(sed "${_j}q;d" "$linkmapfile")"
		_ls="$(echo "$_range" | cut -d' ' -f1)"
		_le="$(echo "$_range" | cut -d' ' -f2)"
		[ -z "$_le" ] && _le="$_ls"
		if [ "$_ls" -ge "$viewstart" ] && [ "$_le" -le "$viewend" ]
		then
			selected="$_j"
			selstart=0
			selend=0
			paint_range "$_old_s" "$_old_e"
			load_selection_range
			paint_range "$selstart" "$selend"
			return
		fi
		_j=$((_j + 1))
	done
}

# Arrow selection: repaint only old/new lines, scroll incrementally if needed
pager_move_selection() {
	_dir="$1"
	[ "$nlinks" -lt 1 ] && return 1
	_new=$((selected + _dir))
	[ "$_new" -lt 1 ] && return 1
	[ "$_new" -gt "$nlinks" ] && return 1

	_old_s="$selstart"
	_old_e="$selend"
	_old_view="$viewstart"

	selected="$_new"
	load_selection_range
	_need="$(pager_needed_viewstart)"

	if [ "$_need" -eq "$_old_view" ]
	then
		selstart=0
		selend=0
		paint_range "$_old_s" "$_old_e"
		load_selection_range
		paint_range "$selstart" "$selend"
	else
		selstart=0
		selend=0
		paint_range "$_old_s" "$_old_e"
		pager_scroll_by $((_need - _old_view))
		load_selection_range
		paint_range "$selstart" "$selend"
	fi
	return 0
}

# Page/line scroll for text pages or explicit page keys
pager_scroll_and_select() {
	_delta="$1"
	_old_s="$selstart"
	_old_e="$selend"
	_old_sel="$selected"
	if pager_scroll_by "$_delta"
	then
		if [ "$nlinks" -gt 0 ] && [ "$_old_sel" -gt 0 ]
		then
			# Attributes shift with scrolled cells; fix selection if it left the viewport
			pager_sync_viewend
			if [ "$_old_s" -lt "$viewstart" ] || [ "$_old_e" -gt "$viewend" ]
			then
				selected="$_old_sel"
				selstart=0
				selend=0
				paint_range "$_old_s" "$_old_e"
				selected="$_old_sel"
				pager_select_visible
			fi
		fi
	fi
}

pager() {
	pagerfile="$1"
	lines="$(tput lines)"
	contentrows=$((lines - 1))
	[ "$contentrows" -lt 1 ] && contentrows=1
	l="$(wc -l < "$pagerfile" | tr -d ' ')"
	[ -z "$l" ] && l=0
	nlinks=0
	[ -f "$linkmapfile" ] && nlinks="$(wc -l < "$linkmapfile" | tr -d ' ')"
	[ -z "$nlinks" ] && nlinks=0

	viewstart=1
	viewend=0
	selected=0
	selstart=0
	selend=0
	if [ "$nlinks" -gt 0 ]
	then
		selected=1
		load_selection_range
	fi

	stty -echo -icanon min 1 time 0
	pager_draw

	_nl="$(printf '\n')"
	_cr="$(printf '\r')"
	_esc="$(printf '\033')"

	while k="$(dd bs=1 count=1 status=none 2>/dev/null)"
	do
		case "$k" in
		"$_esc")
			b="$(dd bs=2 count=1 status=none 2>/dev/null)"
			case "$b" in
				'[A')
					if [ "$nlinks" -gt 0 ]
					then
						pager_move_selection -1
					else
						pager_scroll_by -1
					fi
					;;
				'[B')
					if [ "$nlinks" -gt 0 ]
					then
						pager_move_selection 1
					else
						pager_scroll_by 1
					fi
					;;
				'[C')
					if hist_navigate 1
					then
						return
					fi
					printf '\033[%s;1H\033[2KNo next page.' "$lines"
					sleep 1
					printf '\033[?25l'
					pager_clear_status
					;;
				'[D')
					if hist_navigate -1
					then
						return
					fi
					printf '\033[%s;1H\033[2KNo previous page.' "$lines"
					sleep 1
					printf '\033[?25l'
					pager_clear_status
					;;
				'[5')
					dd bs=1 count=1 status=none > /dev/null 2>&1
					pager_scroll_and_select $((1 - contentrows))
					;;
				'[6')
					dd bs=1 count=1 status=none > /dev/null 2>&1
					pager_scroll_and_select "$contentrows"
					;;
			esac ;;
		"$_nl"|"$_cr")
			if [ "$nlinks" -gt 0 ] && [ "$selected" -gt 0 ]
			then
				if follow_link "$selected"
				then
					return
				fi
				pager_draw
			fi
			;;
		"$quitkey") thetrap ;;
		"$openkey")
			printf '\033[%s;1H\033[?25h\033[2KType url: ' "$lines"
			stty echo icanon
			read -r url
			case "$url" in
			       "gopher://"*) ;;
			       *) url="gopher://$url" ;;
			esac
			return
			;;
		"$openlocalkey")
			printf '\033[%s;1H\033[?25h\033[2KType file path: ' "$lines"
			stty echo icanon
			read -r file
			if [ -f "$file" ]
			then
				typesetgopher < "$file" > "$pagefile"
				pager "$pagefile"
			fi
			return
			;;
		"$refreshkey") histskip=1; return ;;
		"$backkey")
			if hist_navigate -1
			then
				return
			fi
			printf '\033[%s;1H\033[2KNo previous page.' "$lines"
			sleep 1
			stty -echo -icanon min 1 time 0
			printf '\033[?25l'
			pager_clear_status
			;;
		"$homekey") url="$homepage"; gophersearch=""; return ;;
		"$markkey")
			printf '\033[%s;1H\033[?25h\033[2KEnter description: (optional) ' "$lines"
			stty echo icanon
			read -r desc
			echo "$url $desc" >> "$bookmarkfile"
			return
			;;
		"$gomarkkey")
			clear
			if [ -f "$bookmarkfile" ]
			then
				cat -n "$bookmarkfile"
			else
				echo "(no bookmarks)"
			fi
			printf "\033[?25h\033[KEnter bookmark number: "
			stty echo icanon
			read -r i
			url="$(sed "${i}q;d" "$bookmarkfile" | cut -d' ' -f1)"
			gophersearch=""
			return
			;;
		"$delmarkkey")
			if [ -f "$bookmarkfile" ]
			then
				grep -iv "^$url " "$bookmarkfile" > "$cachedir/bookmarks"
				mv "$cachedir/bookmarks" "$bookmarkfile"
			fi
			return
			;;
		"$goupkey")
			if [ -n "$oldselector" ]
			then
				upsel="$(echo "$oldselector" | sed 's|/*[^/]*/*$||')"
				url="gopher://$oldhost:${oldport:-70}/1$upsel"
			else
				url="gopher://$oldhost:${oldport:-70}/1/"
			fi
			gophersearch=""
			return
			;;
		"$savekey")
			printf '\033[%s;1H\033[?25h\033[2KSave to file: ' "$lines"
			stty echo icanon
			read -r savepath
			if [ -n "$savepath" ]
			then
				cp "$rawfile" "$savepath" 2>/dev/null || cp "$pagefile" "$savepath"
				printf '\033[2KSaved to %s. Press enter.' "$savepath"
				read -r _
			fi
			stty -echo -icanon min 1 time 0
			printf '\033[?25l'
			pager_draw
			;;
		esac
	done
}

# Send gopher request via netcat/openssl fallback
# Parameters: host, port, selector_payload
gopher_request() {
	reqhost="$1"
	reqport="$2"
	reqsel="$3"

	# Prefer nc/netcat; fall back to /dev/tcp via a tiny sh trick is not portable
	if command -v nc >/dev/null 2>&1
	then
		printf '%s\r\n' "$reqsel" | nc -w 15 "$reqhost" "$reqport"
	elif command -v netcat >/dev/null 2>&1
	then
		printf '%s\r\n' "$reqsel" | netcat -w 15 "$reqhost" "$reqport"
	elif command -v ncat >/dev/null 2>&1
	then
		printf '%s\r\n' "$reqsel" | ncat -w 15 "$reqhost" "$reqport"
	elif command -v socat >/dev/null 2>&1
	then
		printf '%s\r\n' "$reqsel" | socat -T15 - TCP:"$reqhost":"$reqport"
	else
		echo "geomys: need nc, netcat, ncat, or socat to connect" >&2
		return 1
	fi
}

# Fetches the gopher response from server
# Parameters: proto, host, port, itype, selector
fetch() {
	if [ ! "$1" = "gopher" ]
	then
		echo "Only gopher links are supported."
		echo "Type a key to continue."
		read -r i
		hist_restore_current
		debug "previous page: $url"
		return
	fi

	# Guard against empty/broken history restores
	if [ -z "$2" ]
	then
		url="$homepage"
		histskip=""
		return
	fi

	debug "requesting $1://$2:$3/$4$5"

	# set title
	printf '\033]2;%s\007' "geomys (c): $2/$4$5"

	_hist_record=1
	if [ -n "$histskip" ]
	then
		_hist_record=0
		histskip=""
	fi

	# Build selector for wire: search queries append TAB + query
	wiresel="$5"
	if [ "$4" = "7" ] && [ -n "$gophersearch" ]
	then
		wiresel="$5	$gophersearch"
	fi

	# Port display for URL
	portdisp=""
	[ "$3" != "70" ] && portdisp=":$3"
	url="$1://$2$portdisp/$4$5"
	[ "$trace" ] && echo "url: $url selector: $wiresel" >> "$tracefile"

	if ! gopher_request "$2" "$3" "$wiresel" > "$rawfile" 2>/dev/null
	then
		echo "Connection failed to $2:$3" >&2
		echo "Type a key to continue."
		read -r i
		hist_restore_current
		return 0
	fi

	# Empty response?
	if [ ! -s "$rawfile" ]
	then
		echo "Empty response from $2:$3" >&2
		echo "Type a key to continue."
		read -r i
		hist_restore_current
		return 0
	fi

	printf '\033]2;%s\007' "geomys (r): $2/$4$5"

	# Success — record history for normal navigation only
	if [ "$_hist_record" -eq 1 ]
	then
		hist_push "$1" "$2" "$3" "$4" "$5"
	fi

	oldhost="$2"
	oldport="$3"
	olditype="$4"
	oldselector="$5"

	printf '\033]2;%s\007' "geomys (t): $2/$4$5"
	case "$4" in
		1|7)
			# Menu / search results
			typesetgopher < "$rawfile" > "$pagefile"
			;;
		0)
			# Text file
			typesettext < "$rawfile" > "$pagefile"
			;;
		3)
			# Error — still try to render as menu
			typesetgopher < "$rawfile" > "$pagefile"
			;;
		9|4|5|6|g|I|s)
			# Binary / media — not rendered, offer save
			clear
			printf "Binary/media item (type %s): gopher://%s:%s/%s%s\n\n" "$4" "$2" "$3" "$4" "$5"
			printf "Save to file? Enter path (or empty to skip): "
			stty echo icanon
			read -r savepath
			if [ -n "$savepath" ]
			then
				cp "$rawfile" "$savepath"
				printf "Saved %s bytes to %s\n" "$(wc -c < "$rawfile" | tr -d ' ')" "$savepath"
			fi
			printf "Press enter to go back."
			read -r _
			if ! hist_navigate -1
			then
				hist_restore_current
			fi
			return 0
			;;
		h)
			# HTML item — show raw or note unsupported
			typesettext < "$rawfile" > "$pagefile"
			;;
		*)
			# Default: try as menu
			typesetgopher < "$rawfile" > "$pagefile"
			;;
	esac

	debug "starting pager"
	printf '\033]2;%s\007' "geomys (l): $2/$4$5"
	gophersearch=""
	pager "$pagefile"

	debug "new url: $url"
}

# files are handled differently
if [ "$file" ] && [ -f "$file" ]
then
	typesetgopher < "$file" > "$pagefile"
	pager "$pagefile"
fi

# first request
url="${url:-$homepage}"
# ensure protocol prefix for homepage convenience
case "$url" in
	"gopher://"*) ;;
	*) url="gopher://$url" ;;
esac

gophersearch=""
while :
do
	printf '\033]2;%s\007' "geomys (w)"

	# shellcheck disable=SC2046
	fetch $(parseurl)
done
